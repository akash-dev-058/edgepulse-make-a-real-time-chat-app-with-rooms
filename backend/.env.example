# RealTimeChatApp Backend Environment Variables
# Copy this file to .env.local and fill in your values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
SERVE_STATIC=false

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/chatapp

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-rs256-secret-min-32-chars-here
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Socket.IO
SOCKET_IO_SECRET=socket-io-secret-min-32-chars

# Security
CORS_ORIGINS=http://localhost:3000

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@chatapp.com

# Sentry
SENTRY_DSN=

# Auth (NextAuth)
NEXTAUTH_SECRET=next-auth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT=100
